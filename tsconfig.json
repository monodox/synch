{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "test/createSynch.test.ts", "test/runner.test.ts", "test/router.test.ts", "test/state.test.ts", "test/cache.test.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
