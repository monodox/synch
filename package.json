{
  "name": "synch",
  "version": "1.0.0",
  "description": "Open-source Node.js runtime for executing AI tasks efficiently through computation reuse, state management, and intelligent caching",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "synch": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "start": "node dist/bin.js serve",
    "cli": "node dist/bin.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "runtime",
    "cache",
    "state-management",
    "computation-reuse",
    "llm",
    "inference",
    "optimization",
    "node",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/monodox/synch.git"
  },
  "bugs": {
    "url": "https://github.com/monodox/synch/issues"
  },
  "homepage": "https://github.com/monodox/synch#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
